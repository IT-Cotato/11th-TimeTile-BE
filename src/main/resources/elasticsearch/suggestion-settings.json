{
  "analysis": {
    "analyzer": {
      "korean_english_analyzer": {
        "type": "custom",
        "tokenizer": "nori_tokenizer",
        "filter": [
          "lowercase",
          "synonym_graph_filter",
          "nori_readingform",
          "ngram_filter"
        ]
      },
      "edge_ngram_analyzer": {
        "type": "custom",
        "tokenizer": "edge_ngram_tokenizer",
        "filter": [
          "lowercase"
        ]
      }
    },
    "filter": {
      "ngram_filter": {
        "type": "ngram",
        "min_gram": 2,
        "max_gram": 5,
        "token_chars": [
          "letter",
          "digit"
        ]
      },
      "synonym_graph_filter": {
        "type": "synonym_graph",
        "synonyms_path": "synonyms.txt"
      }
    }
  }
}